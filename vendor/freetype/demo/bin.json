{
  "name": "freetype-demo",
  "description": "FreeType text rendering demo (renders TTF to BMP)",
  "includes": [
    ".",
    "../include",
    "../include/freetype/internal"
  ],
  "compilerArgs": [
    "-DFT2_BUILD_LIBRARY",
    "-DFT_MAKE_OPTION_SINGLE_OBJECT"
  ],
  "dataFiles": {
    "robotomono.ttf": "/font.ttf"
  },
  "sources": [
    "../src/base/ftbase.c",
    "../src/base/ftsystem.c",
    "../src/base/ftdebug.c",
    "../src/base/ftinit.c",
    "../src/base/ftbitmap.c",
    "../src/sfnt/sfnt.c",
    "../src/truetype/truetype.c",
    "../src/smooth/smooth.c",
    "../src/psnames/psnames.c",
    "main.c"
  ]
}
